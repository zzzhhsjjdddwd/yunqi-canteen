# Dependencies
node_modules/
**/node_modules/

# Build outputs (we only ship dist-static/)
dist/
**/dist/
!dist-static/
!dist-static/**

# Vite/PWA build artifacts (should only exist in dist/, not in source)
client/assets/
admin/assets/
client/sw.js
client/workbox-*.js
client/registerSW.js
client/tsconfig.tsbuildinfo
admin/sw.js
admin/workbox-*.js
admin/registerSW.js
admin/tsconfig.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
server/server.log
server/server.err.log

# Environment files
.env
.env.local
.env.*.local
**/.env
!server/.env.example
!client/.env.production.example
!admin/.env.production.example

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Misc
*.tsbuildinfo
.cache/
.tmp/
coverage/

# Uploaded files (runtime data)
server/uploads/
**/uploads/

# Database (runtime data)
server/src/prisma/dev.db
server/src/prisma/*.db
server/src/prisma/*.db-journal

# Temp directories
temp/
**/temp/

# Root-level screenshots / demo images
/admin_step*.png
/client_test.png
/test_*.png
/test_*.js
/test_*.txt
